{
  "info": {
    "name": "Codehause API",
    "description": "Auth (register/login/refresh/logout/me), client self-service (profile/password/deactivate), and admin client management (list/get/activate/deactivate/delete). Run top-to-bottom within a folder — requests auto-capture tokens/ids into collection variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "clientEmail", "value": "", "type": "string" },
    { "key": "clientPassword", "value": "", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "clientId", "value": "", "type": "string" },
    { "key": "adminEmail", "value": "", "type": "string" },
    { "key": "adminPassword", "value": "", "type": "string" },
    { "key": "adminAccessToken", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('clientEmail', 'postman.client.' + Date.now() + '@example.test');",
                  "pm.collectionVariables.set('clientPassword', 'StrongPass123');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "const data = pm.response.json();",
                  "if (data.success && data.data) {",
                  "  pm.collectionVariables.set('accessToken', data.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', data.data.refreshToken);",
                  "  pm.collectionVariables.set('clientId', String(data.data.user.userId));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Postman\",\n  \"lastName\": \"Client\",\n  \"contactNo\": \"09171234567\",\n  \"email\": \"{{clientEmail}}\",\n  \"password\": \"{{clientPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json();",
                  "if (data.success && data.data) {",
                  "  pm.collectionVariables.set('accessToken', data.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', data.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{clientEmail}}\",\n  \"password\": \"{{clientPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "login"]
            }
          }
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "me"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json();",
                  "if (data.success && data.data) {",
                  "  pm.collectionVariables.set('accessToken', data.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', data.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/users/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "refresh"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/users/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "logout"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Client Self-Service",
      "item": [
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"PostmanUpdated\",\n  \"address\": \"123 Sample Street\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "me"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Change My Password",
          "request": {
            "method": "PATCH",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"{{clientPassword}}\",\n  \"newPassword\": \"NewerPass456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/me/password",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "me", "password"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "if (pm.response.code === 200) { pm.collectionVariables.set('clientPassword', 'NewerPass456'); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Deactivate My Account",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"password\": \"{{clientPassword}}\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/users/me/deactivate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "me", "deactivate"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Admin - Client Management",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "const data = pm.response.json();",
                  "if (data.success && data.data) {",
                  "  pm.collectionVariables.set('adminAccessToken', data.data.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "login"]
            }
          }
        },
        {
          "name": "List Clients",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminAccessToken}}" }]
            },
            "url": {
              "raw": "{{baseUrl}}/api/users?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Client By Id",
          "request": {
            "method": "GET",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminAccessToken}}" }]
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{clientId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{clientId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Activate Client",
          "request": {
            "method": "PATCH",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminAccessToken}}" }]
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{clientId}}/activate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{clientId}}", "activate"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Deactivate Client",
          "request": {
            "method": "PATCH",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminAccessToken}}" }]
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{clientId}}/deactivate",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{clientId}}", "deactivate"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Client",
          "request": {
            "method": "DELETE",
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{adminAccessToken}}" }]
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/{{clientId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{clientId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
